# QIF Sanitizer Configuration File
# This file contains settings for the QIF sanitizer tool

# Path to the file containing category mappings
# This file should contain mappings in the format: QuickenCategory = GnuCashAccountName
MAPPINGS_FILE = "quicken_gnucash_mappings.txt"

# Directory-based batch processing settings
# If INPUT_DIR is set, the sanitizer will scan this directory for all .qif/.QIF files
# and process them in batch mode. If left empty, the tool operates in single-file mode.
INPUT_DIR = "quicken_export_files"
OUTPUT_DIR = "gnucash_import_files"
