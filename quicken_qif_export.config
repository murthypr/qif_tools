# Quicken QIF Export Configuration
# This file contains settings for automating QIF exports from Quicken

# Run mode: dry-run or prod
# dry-run = discover accounts only, no exports
# prod    = discover accounts AND export QIF files
# Can be overridden with --dry-run or --prod CLI flags
RUN_MODE = prod

# Output directory for exported QIF files
OUTPUT_DIR = "quicken_export_files"

# Skip accounts that already have a QIF file in OUTPUT_DIR
# Set to false to force re-export of all accounts
SKIP_EXISTING = true

# Max number of accounts to export in a single run.
# Set to ALL to export every account discovered from Quicken.
# Useful for testing — e.g., set to 10 to do a small batch first.
MAX_EXPORTS = 10

# Quicken window title (partial match) — used to find the running instance
# If you have multiple Quicken windows open, make this more specific
QUICKEN_WINDOW_TITLE = "Quicken"

# Log file path (relative to this config file's directory)
LOG_FILE = "quicken_export.log"

# Delay (seconds) between each account export to let Quicken settle
# Increase this if Quicken is very slow or becomes unresponsive
DELAY_BETWEEN_ACCOUNTS = 2

# --- UI Timing Delays (seconds) ---
# Reduce these for faster runs; increase if Quicken becomes unresponsive.
# DELAY_KEYSTROKE: after keyboard input (focus changes, Ctrl+A, typing, Escape, Enter)
DELAY_KEYSTROKE = 0.3
# DELAY_MENU: after menu navigation (Alt+F, Alt+A, Alt+Q, Alt+E)
DELAY_MENU = 0.5
# DELAY_COMBO_ENUM: between combo box items during enumeration (can be 0)
DELAY_COMBO_ENUM = 0.01
# DELAY_DIALOG_ACTION: after button clicks and for dialog/file polling
DELAY_DIALOG_ACTION = 0.5
# DELAY_IDLE_POLL: polling interval when waiting for Quicken idle
DELAY_IDLE_POLL = 2.0

# Max seconds to wait for Quicken to respond before timing out
TIMEOUT = 60
